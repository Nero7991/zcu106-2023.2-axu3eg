/include/ "system-conf.dtsi"
/ {
	misc_clk_a: misc_clk_a {
		#clock-cells = <0>;
		clock-frequency = <12000000>;
		compatible = "fixed-clock";
	};
	cam_reg_1v8: regulator-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "1v8";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
	};
	cam_reg_2v8: regulator-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "2v8";
		regulator-min-microvolt = <2800000>;
		regulator-max-microvolt = <2800000>;
	};
	cam_reg_1v5: regulator-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "1v5";
		regulator-min-microvolt = <1500000>;
		regulator-max-microvolt = <1500000>;
	};

};

&i2c1 {
        clock-frequency = <400000>;
        eeprom@50{
                compatible = "atmel,24c04";
                reg = <0x50>;
                pagesize = <16>;
        };
};

&i2c1 {
        clock-frequency = <400000>;
        lm75@48 {
                compatible = "nxp,lm75";
                reg = <0x48>;
        };
};

&qspi {
        status = "okay";
};

&flash0 {
	is-dual = <0>;
	num-cs = <1>;
	spi-rx-bus-width = <4>;
        spi-tx-bus-width = <4>;
        compatible ="jedec,spi-nor";
        reg= <0x0>;
};

&gem3 {
	phy-handle = <&phy0>;
    local-mac-address = [00 0a 35 00 22 01];
	phy0: ethernet-phy@c {
		reg = <0x0>;
	};
};

&axi_ethernet_0 {
	phy-handle = <&phy2>;
};

&axi_ethernet_0_mdio {
	phy2: phy@2 {
		device_type = "ethernet-phy";
		reg = <1>;
	};
};

&i2c0 {
	ov5640: camera@3c {
		compatible = "ovti,ov5640";
		reg = <0x3c>;
		clocks = <&misc_clk_a>;
		clock-names = "xclk";
		/* rotation = <180>; */
		DOVDD-supply = <&cam_reg_1v8>;
		AVDD-supply = <&cam_reg_2v8>;
		DVDD-supply = <&cam_reg_1v5>;
		port {
			/* MIPI CSI-2 bus endpoint */
			ov5640_to_mipi_csi2: endpoint {
				remote-endpoint = <&csiss_in>;
				clock-lanes = <0>;
				data-lanes = <1 2>;
			};
		};
	};
};


&mipi_csi2_rx_subsyst_0{
	compatible = "xlnx,mipi-csi2-rx-subsystem-2.0";
	csiss_ports: ports {
		#address-cells = <1>;
		#size-cells = <0>;
		csiss_port0: port@0 {
			reg = <0>;

			xlnx,video-format = <0>;
			xlnx,video-width = <8>;

			csiss_out: endpoint {
				remote-endpoint = <&csc_in>;
			};
		};
		csiss_port1: port@1 {
			reg = <1>;

			xlnx,video-format = <0>;
			xlnx,video-width = <8>;

			csiss_in: endpoint {
				data-lanes = <1 2>;
				remote-endpoint = <&ov5640_to_mipi_csi2>;
			};
		};
	};
};

&v_proc_ss_0{
	compatible = "xlnx,v-vpss-csc";
	reset-gpios = <&gpio 86 1>;
	csc_ports: ports {
		#address-cells = <1>;
		#size-cells = <0>;
		csc_port0: port@0 {
			reg = <0>;
			xlnx,video-format = <3>;
			xlnx,video-width = <8>;
			csc_in: endpoint {
				remote-endpoint = <&csiss_out>;
			};
		};
		csc_port1: port@1 {
			reg = <1>;
			xlnx,video-format = <3>;
			xlnx,video-width = <8>;
			csc_out: endpoint {
				remote-endpoint = <&vcap_in>;
			};
		};
	};
};


&v_frmbuf_wr_0 {
	compatible = "xlnx,axi-frmbuf-wr-v2.1";
	reset-gpios = <&gpio 85 1>;
};

&amba_pl {
	vcap_mipi {
		compatible = "xlnx,video";
		dma-names = "port0";
		dmas = <&v_frmbuf_wr_0 0>;
		vcap_ports: ports {
			#address-cells = <1>;
			#size-cells = <0>;
			vcap_port: port@0 {
				direction = "input";
				reg = <0>;
				vcap_in: endpoint {
					remote-endpoint = <&csc_out>;
				};
			};
		};
	};
	/* The FPD thermal diode is remotely located near the APUs */
	temp_apu: thermal-sensor@ffa50a14 {
		compatible = "xlnx,zynqmp-pssysmon-temp";
		#thermal-sensor-cells = <0>;
		reg = <0x0 0xffa50a14 0x0 0x2>;
		type = "temp-sensor";
		id = <0>;
	};
	/* The thermal diode is located in the PL SysMon unit */
	temp_pl: thermal-sensor@ffa50c00 {
		compatible = "xlnx,zynqmp-pssysmon-temp";
		#thermal-sensor-cells = <0>;
		reg = <0x0 0xffa50c00 0x0 0x2>;
		type = "temp-sensor";
		id = <0>;
	};
	/* The LPD thermal diode is located in the PS SysMon unit near the RPU */
	temp_ps: thermal-sensor@ffa50800 {
		compatible = "xlnx,zynqmp-pssysmon-temp";
		#thermal-sensor-cells = <0>;
		reg = <0x0 0xffa50800 0x0 0x2>;
		type = "temp-sensor";
		id = <0>;
	};
};

/* SD */
&sdhci1 {
	disable-wp;
	no-1-8-v;
};

/* USB  */
&dwc3_0 {
    status = "okay";
    dr_mode = "host";
};

/* USB  */
&dwc3_0 {
    status = "okay";
    dr_mode = "host";
};


/ {

	cooling_device: gpio-fan {
		compatible = "xlnx,soft-pwm-fan";
		type = "cooling-fan";
		status = "okay";
		/*
		 * Fan is wired active-low (driving the line to 0 turns the fan
		 * on). Express that with GPIO_ACTIVE_LOW so the driver can use
		 * plain logical levels (asserted == fan on).
		 */
		gpios = <&fan_gpio 0 GPIO_ACTIVE_LOW>;
		num-levels = <10>;        /* cooling states 1..10 (0 = off)     */
		min-duty-percent = <30>;  /* lowest duty that keeps it spinning */
		pwm-frequency-hz = <100>; /* soft-PWM carrier frequency         */
		#cooling-cells = <2>;     /* <min-state max-state> in the maps  */
	};

	/*
	 * Proportional (soft-PWM) fan control. Each zone has a staircase of
	 * active trips from 45 C to 75 C; the step_wise governor ramps the
	 * cooling device across the state band bound at each trip, so fan speed
	 * rises with temperature instead of slamming fully on. num-levels = 10,
	 * so state bands span 0..10 (0 = off, 10 = full). 3 C hysteresis keeps
	 * the staircase responsive without chattering. 95 C stays critical.
	 * The thermal core drives the fan to the highest state any zone asks
	 * for, so the hottest sensor wins.
	 */
	thermal-zones {
		apu_thermal: apu-thermal {
			polling-delay = <1000>;
			polling-delay-passive = <500>;
			thermal-sensors = <&temp_apu>;
			trips {
				apu_crit: apu_crit {
					temperature = <95000>;
					hysteresis = <2000>;
					type = "critical";
				};
				apu_t0: apu_t0 { temperature = <45000>; hysteresis = <3000>; type = "active"; };
				apu_t1: apu_t1 { temperature = <55000>; hysteresis = <3000>; type = "active"; };
				apu_t2: apu_t2 { temperature = <65000>; hysteresis = <3000>; type = "active"; };
				apu_t3: apu_t3 { temperature = <75000>; hysteresis = <3000>; type = "active"; };
			};
			cooling-maps {
				apu_map0 { trip = <&apu_t0>; cooling-device = <&cooling_device 0 3>; };
				apu_map1 { trip = <&apu_t1>; cooling-device = <&cooling_device 3 6>; };
				apu_map2 { trip = <&apu_t2>; cooling-device = <&cooling_device 6 8>; };
				apu_map3 { trip = <&apu_t3>; cooling-device = <&cooling_device 8 10>; };
			};
		};
		pl_thermal: pl-thermal {
			polling-delay = <1000>;
			polling-delay-passive = <500>;
			thermal-sensors = <&temp_pl>;
			trips {
				pl_crit: pl_crit {
					temperature = <95000>;
					hysteresis = <2000>;
					type = "critical";
				};
				pl_t0: pl_t0 { temperature = <45000>; hysteresis = <3000>; type = "active"; };
				pl_t1: pl_t1 { temperature = <55000>; hysteresis = <3000>; type = "active"; };
				pl_t2: pl_t2 { temperature = <65000>; hysteresis = <3000>; type = "active"; };
				pl_t3: pl_t3 { temperature = <75000>; hysteresis = <3000>; type = "active"; };
			};
			cooling-maps {
				pl_map0 { trip = <&pl_t0>; cooling-device = <&cooling_device 0 3>; };
				pl_map1 { trip = <&pl_t1>; cooling-device = <&cooling_device 3 6>; };
				pl_map2 { trip = <&pl_t2>; cooling-device = <&cooling_device 6 8>; };
				pl_map3 { trip = <&pl_t3>; cooling-device = <&cooling_device 8 10>; };
			};
		};
		ps_thermal: ps-thermal {
			polling-delay = <1000>;
			polling-delay-passive = <500>;
			thermal-sensors = <&temp_ps>;
			trips {
				ps_crit: ps_crit {
					temperature = <95000>;
					hysteresis = <2000>;
					type = "critical";
				};
				ps_t0: ps_t0 { temperature = <45000>; hysteresis = <3000>; type = "active"; };
				ps_t1: ps_t1 { temperature = <55000>; hysteresis = <3000>; type = "active"; };
				ps_t2: ps_t2 { temperature = <65000>; hysteresis = <3000>; type = "active"; };
				ps_t3: ps_t3 { temperature = <75000>; hysteresis = <3000>; type = "active"; };
			};
			cooling-maps {
				ps_map0 { trip = <&ps_t0>; cooling-device = <&cooling_device 0 3>; };
				ps_map1 { trip = <&ps_t1>; cooling-device = <&cooling_device 3 6>; };
				ps_map2 { trip = <&ps_t2>; cooling-device = <&cooling_device 6 8>; };
				ps_map3 { trip = <&ps_t3>; cooling-device = <&cooling_device 8 10>; };
			};
		};
	};
};



